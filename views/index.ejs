<%- include("head.partial.ejs") %>

  </section>
    <% if (error == 1) { %>
      <div class="error-box">This name has been already used</div>
    <% } %>
    <h1 class="main-header">Cool and useful stuff</h1>
      <div class="category-container">
      <% if(categories != 0){
        categories.forEach((category, index) => { %>
        <div class="category-box">
        <a href="/<%= category.name %>" class="category-link">
          <p><%= category.name.toUpperCase() %></p>
        </a>
          <% if (category.parent){ %>
          <form action="deleteCategory" method="POST">
            <button type="submit" name="delete_id" value="<%= category.id %>" class="delete">DELETE</button>
          </form>
          <% } %>
          </div>
      <% })} %>
    <div class="category-box">
    <form action="/newCategory" method="POST" class="category-form">
        <input 
        name="name"
        placeholder="name"
        type="text"
        required
        maxlength="25"
        class="new-category-input"
        >
        <div class="checkbox-row">
        <input type="checkbox" name="published" value="1" id="published">
        <label for="published">Published</label>
        </div>
        <button class="delete add">ADD</button>
      </form>
    </div></div>

  </main>
<%- include("foot.partial.ejs") %>